@using BlogApp.ViewModels
@model LoginViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<main class="flex-1 flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold">Welcome back</h1>
            <p class="text-gray-500 mt-2">Sign in to your account</p>
        </div>

        <!-- Validation summary -->
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

        <form asp-action="Login" asp-controller="Account" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Email -->
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input asp-for="Email" placeholder="maya@example.com"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <!-- Password -->
            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input asp-for="Password" placeholder="••••••••"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
            </div>

            <!-- Remember me & Forgot password -->
            <div class="flex items-center justify-between text-sm">
                <label class="flex items-center gap-2">
                    <input asp-for="RememberMe" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-300" />
                    <span class="text-gray-600">Remember me</span>
                </label>
                <a asp-action="ForgotPassword" asp-controller="Account" class="text-indigo-600 hover:underline">
                    Forgot password?
                </a>
            </div>

            <!-- Submit -->
            <button type="submit"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 rounded-xl transition shadow-sm">
                Sign in
            </button>
        </form>

        <!-- Divider -->
        <div class="relative my-6">
            <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-gray-200"></div>
            </div>
            <div class="relative flex justify-center text-sm">
                <span class="px-4 bg-white text-gray-400">or</span>
            </div>
        </div>

        <!-- Social login -->
        <div class="grid grid-cols-2 gap-3">
            <button disabled class="flex items-center justify-center gap-2 border border-gray-200 rounded-xl py-2.5 text-sm opacity-50 cursor-not-allowed">
                <i class="fab fa-google text-indigo-400"></i> Google
            </button>
            <button disabled class="flex items-center justify-center gap-2 border border-gray-200 rounded-xl py-2.5 text-sm opacity-50 cursor-not-allowed">
                <i class="fab fa-github"></i> GitHub
            </button>
        </div>

        <!-- Register link -->
        <p class="text-center text-sm text-gray-500 mt-6">
            Don't have an account?
            <a asp-action="Register" asp-controller="Account" class="text-indigo-600 font-medium hover:underline">
                Sign up
            </a>
        </p>
    </div>
</main>

<footer class="bg-white border-t border-gray-100 py-6 text-center text-sm text-gray-400">
    © 2025 zenblog ·
    <a asp-action="Index" asp-controller="Home" class="hover:text-indigo-600">Home</a> ·
    <a href="#" class="hover:text-indigo-600">Privacy</a>
</footer>