@using BlogApp.ViewModels
@model RegisterViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Create account";
}

<main class="flex-1 flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <div class="text-center mb-8">
            <a href="/" class="text-2xl font-bold text-indigo-600 tracking-tight">zen<span class="text-gray-800">blog</span></a>
            <h1 class="text-3xl font-bold mt-4">Join zenblog</h1>
            <p class="text-gray-500 mt-2">Create an account to start writing</p>
        </div>

        <form asp-action="Register" asp-controller="Account" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <!-- Validation summary -->
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-2"></div>

            <!-- First Name & Last Name -->
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">First name</label>
                    <input asp-for="FirstName" placeholder="Alex"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="FirstName" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1">Last name</label>
                    <input asp-for="LastName" placeholder="River"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300" />
                    <span asp-validation-for="LastName" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <!-- Email -->
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input asp-for="Email" placeholder="hello@zenblog.com"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <!-- Password -->
            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input asp-for="Password" placeholder="at least 6 characters"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300" />
                <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
            </div>

            <!-- Confirm Password -->
            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1">Confirm password</label>
                <input asp-for="ConfirmPassword" placeholder="••••••••"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300" />
                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm"></span>
            </div>

            <button type="submit"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 rounded-xl transition shadow-sm mt-2">
                Create account
            </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-6">
            Already have an account?
            <a asp-action="Login" asp-controller="Account" class="text-indigo-600 font-medium hover:underline">Sign in</a>
        </p>
    </div>
</main>

<footer class="bg-white border-t border-gray-100 py-6 text-center text-sm text-gray-400">
    © 2025 zenblog · <a asp-action="Index" asp-controller="Home" class="hover:text-indigo-600">Home</a>
</footer>