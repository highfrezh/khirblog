@model AdminTagFormViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Tag";
}

<div class="max-w-lg">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold">New Tag</h1>
        <a asp-action="Index" asp-controller="AdminTag"
           class="text-gray-400 hover:text-indigo-600 transition">
            <i class="fas fa-times text-xl"></i>
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <form asp-action="Create" asp-controller="AdminTag" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input asp-for="Name" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea asp-for="Description" rows="3"
                          class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
            </div>

            <div class="flex gap-3 justify-end pt-4 border-t border-gray-100">
                <a asp-action="Index" asp-controller="AdminTag"
                   class="px-6 py-2.5 border border-gray-200 rounded-full text-sm font-medium transition">
                    Cancel
                </a>
                <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition">
                    Create Tag
                </button>
            </div>
        </form>
    </div>
</div>