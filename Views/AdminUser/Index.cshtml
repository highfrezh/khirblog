@model List<AdminUserViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Users";
}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-bold">Users</h1>
        <p class="text-gray-500 mt-1">Manage all registered users</p>
    </div>
    <span class="bg-indigo-50 text-indigo-700 px-4 py-2 rounded-full text-sm font-medium">
        @Model.Count total users
    </span>
</div>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="text-left px-6 py-4 font-semibold text-gray-600">User</th>
                <th class="text-left px-6 py-4 font-semibold text-gray-600 hidden md:table-cell">Email</th>
                <th class="text-left px-6 py-4 font-semibold text-gray-600">Role</th>
                <th class="text-right px-6 py-4 font-semibold text-gray-600">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
            @foreach (var user in Model)
            {
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-sm">
                                @user.FullName.Substring(0, 1).ToUpper()
                            </div>
                            <span class="font-medium">@user.FullName</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-gray-500 hidden md:table-cell">@user.Email</td>
                    <td class="px-6 py-4">
                        @foreach (var role in user.Roles)
                        {
                            <span class="@(role == "Admin" ? "bg-indigo-50 text-indigo-700" : "bg-gray-100 text-gray-600") px-3 py-1 rounded-full text-xs mr-1">
                                @role
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-2">
                            <!-- Toggle Admin -->
                            <form asp-action="ToggleAdmin" asp-controller="AdminUser" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit"
                                        class="p-2 text-gray-400 hover:text-indigo-600 transition"
                                        title="@(user.IsAdmin ? "Remove Admin" : "Make Admin")">
                                    <i class="fas @(user.IsAdmin ? "fa-user-minus" : "fa-user-shield")"></i>
                                </button>
                            </form>
                            <!-- Delete -->
                            <form asp-action="Delete" asp-controller="AdminUser" method="post"
                                  onsubmit="return confirm('Delete this user?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="p-2 text-gray-400 hover:text-red-500 transition">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>