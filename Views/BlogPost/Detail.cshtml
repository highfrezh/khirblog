@using BlogApp.ViewModels
@model BlogPostDetailViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Title;
}

<!-- Error/Success Messages -->
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-4">
        <i class="fas fa-exclamation-circle mr-2"></i> @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-4">
        <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
    </div>
}

<main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Back Button -->
    <a asp-action="Index" asp-controller="BlogPost"
       class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-indigo-600 transition mb-8">
        <i class="fas fa-arrow-left"></i> Back to articles
    </a>

    <!-- Post Header -->
    <div class="mb-8">

        <!-- Category & Date -->
        <div class="flex items-center gap-3 mb-4">
            <span class="bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full text-sm font-medium">
                @Model.CategoryName
            </span>
            <span class="text-gray-400 text-sm">
                @Model.CreatedAt.ToString("MMM dd, yyyy")
            </span>
            @if (Model.UpdatedAt.HasValue)
            {
                <span class="text-gray-400 text-sm">
                    · Updated @Model.UpdatedAt.Value.ToString("MMM dd, yyyy")
                </span>
            }
        </div>

        <!-- Title -->
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight leading-tight">
            @Model.Title
        </h1>

        <!-- Excerpt -->
        @if (!string.IsNullOrEmpty(Model.Excerpt))
        {
            <p class="text-gray-500 text-xl mt-4 leading-relaxed">@Model.Excerpt</p>
        }

        <!-- Author & Stats -->
        <div class="flex items-center justify-between mt-6 pb-6 border-b border-gray-200">
            <div class="flex items-center gap-3">
                <img src="https://ui-avatars.com/api/?name=@Model.AuthorName&background=4f46e5&color=fff&size=40"
                     class="w-10 h-10 rounded-full" />
                <div>
                    <p class="text-sm font-medium text-gray-800">@Model.AuthorName</p>
                    <p class="text-xs text-gray-400">Author</p>
                </div>
            </div>

            <!-- Action Buttons (Edit/Delete for author or admin) -->
            <div class="flex items-center gap-3">
                @if (User.Identity!.IsAuthenticated &&
                                (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.AuthorId
                                || User.IsInRole("Admin")))
                {
                    <a asp-action="Edit" asp-controller="BlogPost" asp-route-id="@Model.Id"
                       class="text-sm text-gray-500 hover:text-indigo-600 transition">
                        <i class="fas fa-edit mr-1"></i> Edit
                    </a>
                    <form asp-action="Delete" asp-controller="BlogPost" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this post?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="text-sm text-red-400 hover:text-red-600 transition">
                            <i class="fas fa-trash mr-1"></i> Delete
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Cover Image -->
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div class="mb-8">
            <img src="@Model.ImageUrl" alt="@Model.Title"
                 class="w-full max-h-96 object-cover rounded-2xl shadow-sm" />
        </div>
    }

    <!-- Post Content -->
    <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
        @Html.Raw(Model.Content)
    </div>

    <!-- Tags -->
    @if (Model.Tags.Any())
    {
        <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-gray-200">
            @foreach (var tag in Model.Tags)
            {
                <a asp-action="Index" asp-controller="BlogPost"
                   class="bg-gray-100 hover:bg-indigo-100 text-gray-600 hover:text-indigo-700 px-3 py-1.5 rounded-full text-xs transition">
                    #@tag
                </a>
            }
        </div>
    }

    <!-- Like Button -->
    <div class="mt-8 flex items-center gap-4">
        @if (User.Identity!.IsAuthenticated)
        {
            <form asp-action="Toggle" asp-controller="Like" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="blogPostId" value="@Model.Id" />
                <button type="submit"
                        class="flex items-center gap-2 px-5 py-2.5 rounded-full border transition
                                   @(Model.HasLiked ? "bg-red-50 border-red-200 text-red-500 hover:bg-red-100" : "border-gray-200 text-gray-500 hover:border-red-200 hover:text-red-500")">
                    <i class="fas fa-heart"></i>
                    <span>@Model.LikeCount @(Model.LikeCount == 1 ? "Like" : "Likes")</span>
                </button>
            </form>
        }
        else
        {
            <a asp-action="Login" asp-controller="Account"
               class="flex items-center gap-2 px-5 py-2.5 rounded-full border border-gray-200 text-gray-500 hover:border-red-200 hover:text-red-500 transition">
                <i class="fas fa-heart"></i>
                <span>@Model.LikeCount @(Model.LikeCount == 1 ? "Like" : "Likes")</span>
            </a>
        }
    </div>

    <!-- Comments Section -->
    <div class="mt-12">
        <h2 class="text-2xl font-bold mb-6">
            Comments <span class="text-gray-400 font-normal text-lg">(@Model.Comments.Count)</span>
        </h2>

        <!-- Add Comment Form -->
        @if (User.Identity!.IsAuthenticated)
        {
            <form asp-action="Add" asp-controller="Comment" method="post" class="mb-8">
                @Html.AntiForgeryToken()
                <input type="hidden" name="blogPostId" value="@Model.Id" />
                <textarea name="content" rows="3"
                      placeholder="Write a comment..."
                      class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none"></textarea>
                <div class="flex justify-end mt-2">
                    <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition">
                        <i class="fas fa-paper-plane mr-1"></i> Post comment
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="bg-gray-50 rounded-xl p-4 mb-8 text-center text-sm text-gray-500">
                <a asp-action="Login" asp-controller="Account"
                   class="text-indigo-600 font-medium hover:underline">Sign in</a>
                to leave a comment.
            </div>
        }

        <!-- Comments List -->
        @if (Model.Comments.Any())
        {
            <div class="space-y-6">
                @foreach (var comment in Model.Comments)
                {
                    <div class="flex gap-4">
                        <img src="https://ui-avatars.com/api/?name=@comment.AuthorName&background=4f46e5&color=fff&size=36"
                             class="w-9 h-9 rounded-full flex-shrink-0" />
                        <div class="flex-1">
                            <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3">
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-sm font-medium text-gray-800">@comment.AuthorName</span>
                                    <span class="text-xs text-gray-400">@comment.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="text-sm text-gray-600">@comment.Content</p>
                            </div>

                            <!-- Delete comment (author or admin) -->
                            @if (User.Identity!.IsAuthenticated &&
                                                (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.AuthorId
                                                || User.IsInRole("Admin")))
                            {
                                <form asp-action="Delete" asp-controller="Comment" method="post" class="mt-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@comment.Id" />
                                    <input type="hidden" name="blogPostId" value="@Model.Id" />
                                    <button type="submit"
                                            class="text-xs text-red-400 hover:text-red-600 hover:underline transition">
                                        Delete
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <i class="fas fa-comment-slash text-4xl mb-3"></i>
                <p>No comments yet. Be the first to comment!</p>
            </div>
        }
    </div>
</main>