@using BlogApp.ViewModels
@model BlogPostIndexViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "All Articles";
}

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Page title -->
    <div class="text-center md:text-left md:flex md:justify-between md:items-end border-b border-gray-200 pb-6">
        <div>
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight">All articles</h1>
            <p class="text-gray-500 text-lg mt-2">Explore the latest thoughts, stories, and ideas.</p>
        </div>
        <p class="text-indigo-600 font-medium mt-2 md:mt-0">@Model.Posts.Count posts</p>
    </div>

    <!-- Filter & Search -->
    <div class="mt-8 flex flex-col lg:flex-row gap-6 lg:items-start">

        <!-- Sidebar Filters -->
        <aside class="lg:w-1/4 bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
            <h2 class="font-semibold text-lg flex items-center gap-2">
                <i class="fas fa-sliders-h text-indigo-500 text-sm"></i> Filter by
            </h2>

            <!-- Category Filter -->
            <div class="mt-5">
                <h3 class="text-xs uppercase tracking-wider text-gray-400 font-bold">Categories</h3>
                <div class="flex flex-wrap gap-2 mt-3">
                    <a asp-action="Index" asp-controller="BlogPost"
                       class="px-4 py-2 text-sm rounded-full border @(Model.SelectedCategoryId == null ? "border-indigo-600 bg-indigo-600 text-white" : "border-gray-200 bg-white text-gray-700 hover:border-indigo-300") transition">
                        All
                    </a>
                    @foreach (var category in Model.Categories)
                    {
                        <a asp-action="Index" asp-controller="BlogPost"
                           asp-route-categoryId="@category.Id"
                           class="px-4 py-2 text-sm rounded-full border @(Model.SelectedCategoryId == category.Id ? "border-indigo-600 bg-indigo-600 text-white" : "border-gray-200 bg-white text-gray-700 hover:border-indigo-300") transition">
                            @category.Name
                        </a>
                    }
                </div>
            </div>

            <!-- Tag Filter -->
            <div class="mt-6">
                <h3 class="text-xs uppercase tracking-wider text-gray-400 font-bold">Popular tags</h3>
                <div class="flex flex-wrap gap-2 mt-3">
                    @foreach (var tag in Model.Tags)
                    {
                        <a asp-action="Index" asp-controller="BlogPost"
                           asp-route-tagId="@tag.Id"
                           class="px-3 py-1.5 rounded-full text-xs cursor-pointer transition @(Model.SelectedTagId == tag.Id ? "bg-indigo-100 text-indigo-700" : "bg-gray-100 text-gray-700 hover:bg-indigo-100")">
                            #@tag.Name
                        </a>
                    }
                </div>
            </div>

            <!-- Clear Filters -->
            <div class="mt-8">
                <a asp-action="Index" asp-controller="BlogPost"
                   class="text-sm text-indigo-600 hover:underline flex items-center gap-1">
                    <i class="fas fa-redo-alt text-xs"></i> Clear all filters
                </a>
            </div>
        </aside>

        <!-- Posts Grid -->
        <div class="lg:w-3/4">

            <!-- Search Bar -->
            <form asp-action="Index" asp-controller="BlogPost" method="get">
                <div class="bg-white p-1 rounded-full border border-gray-200 flex items-center pl-5 pr-2 shadow-sm">
                    <i class="fas fa-search text-gray-400 mr-2"></i>
                    <input type="text" name="search" value="@Model.SearchKeyword"
                           placeholder="Search articles by title, topic, or keyword..."
                           class="w-full py-3 focus:outline-none text-gray-700" />
                    <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition ml-2 whitespace-nowrap">
                        Search
                    </button>
                </div>
            </form>

            <!-- TempData Success Message -->
            @if (TempData["Success"] != null)
            {
                <div class="mt-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm">
                    <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
                </div>
            }

            <!-- Posts Grid -->
            @if (Model.Posts.Any())
            {
                <div class="grid md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 gap-6 mt-8">
                    @foreach (var post in Model.Posts)
                    {
                        <article class="bg-white rounded-2xl border border-gray-100 p-5 hover-lift transition-soft">

                            <!-- Image or Placeholder -->
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <img src="@post.ImageUrl" alt="@post.Title"
                                     class="w-full h-36 rounded-xl object-cover" />
                            }
                            else
                            {
                                <div class="bg-gray-100 w-full h-36 rounded-xl flex items-center justify-center text-gray-300 text-4xl">
                                    <i class="fas fa-newspaper"></i>
                                </div>
                            }

                            <!-- Category & Date -->
                            <div class="flex items-center gap-2 mt-4 text-xs">
                                <span class="bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full">
                                    @post.CategoryName
                                </span>
                                <span class="text-gray-400">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>

                            <!-- Title -->
                            <h3 class="font-bold text-lg mt-1">
                                <a asp-action="Detail" asp-controller="BlogPost"
                                   asp-route-slug="@post.Slug"
                                   class="hover:text-indigo-600">
                                    @post.Title
                                </a>
                            </h3>

                            <!-- Excerpt -->
                            @if (!string.IsNullOrEmpty(post.Excerpt))
                            {
                                <p class="text-gray-500 text-sm mt-1 line-clamp-2">@post.Excerpt</p>
                            }

                            <!-- Author & Stats -->
                            <div class="flex items-center justify-between mt-4">
                                <div class="flex items-center gap-2">
                                    <img src="https://ui-avatars.com/api/?name=@post.AuthorName&background=4f46e5&color=fff&size=28"
                                         class="w-6 h-6 rounded-full" />
                                    <span class="text-xs text-gray-500">@post.AuthorName</span>
                                </div>
                                <div class="flex items-center gap-3 text-xs text-gray-400">
                                    <span><i class="fas fa-heart mr-1"></i>@post.LikeCount</span>
                                    <span><i class="fas fa-comment mr-1"></i>@post.CommentCount</span>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="mt-12 flex justify-center items-center gap-2">

                        <!-- Previous -->
                        @if (Model.CurrentPage > 1)
                        {
                            <a asp-action="Index" asp-controller="BlogPost"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-search="@Model.SearchKeyword"
                               asp-route-categoryId="@Model.SelectedCategoryId"
                               asp-route-tagId="@Model.SelectedTagId"
                               class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-500 hover:bg-indigo-50 transition">
                                <i class="fas fa-chevron-left text-sm"></i>
                            </a>
                        }

                        <!-- Page Numbers -->
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a asp-action="Index" asp-controller="BlogPost"
                               asp-route-page="@i"
                               asp-route-search="@Model.SearchKeyword"
                               asp-route-categoryId="@Model.SelectedCategoryId"
                               asp-route-tagId="@Model.SelectedTagId"
                               class="w-10 h-10 flex items-center justify-center rounded-full border transition
                                                  @(i == Model.CurrentPage ? "bg-indigo-600 text-white border-indigo-600" : "border-gray-200 text-gray-700 hover:bg-indigo-50")">
                                @i
                            </a>
                        }

                        <!-- Next -->
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a asp-action="Index" asp-controller="BlogPost"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-search="@Model.SearchKeyword"
                               asp-route-categoryId="@Model.SelectedCategoryId"
                               asp-route-tagId="@Model.SelectedTagId"
                               class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-500 hover:bg-indigo-50 transition">
                                <i class="fas fa-chevron-right text-sm"></i>
                            </a>
                        }
                    </div>

                    <!-- Showing X of Y -->
                    <p class="text-center text-sm text-gray-400 mt-6">
                        Showing @((Model.CurrentPage - 1) * 6 + 1)–@(Math.Min(Model.CurrentPage * 6, Model.Posts.Count)) of @Model.Posts.Count posts
                    </p>
                }
            }
            else
            {
                <!-- No Posts Found -->
                <div class="mt-12 text-center py-16">
                    <i class="fas fa-newspaper text-gray-200 text-6xl"></i>
                    <h3 class="text-xl font-bold text-gray-400 mt-4">No posts found</h3>
                    <p class="text-gray-400 mt-2">Try a different search or filter</p>
                    <a asp-action="Index" asp-controller="BlogPost"
                       class="mt-4 inline-block text-indigo-600 hover:underline text-sm">
                        Clear filters
                    </a>
                </div>
            }
        </div>
    </div>
</main>