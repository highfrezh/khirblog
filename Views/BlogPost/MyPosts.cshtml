@model List<BlogPostViewModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = "My Posts";
}

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Page Header -->
    <div class="flex items-center justify-between border-b border-gray-200 pb-6 mb-8">
        <div>
            <h1 class="text-3xl md:text-4xl font-bold">My Posts</h1>
            <p class="text-gray-500 mt-1">Manage your blog posts</p>
        </div>
        <a asp-action="Create" asp-controller="BlogPost"
           class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-full text-sm font-medium transition shadow-sm">
            <i class="fas fa-plus mr-1"></i> New Post
        </a>
    </div>

    <!-- Success Message -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-6">
            <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
        </div>
    }

    <!-- Posts Table -->
    @if (Model.Any())
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="text-left px-6 py-4 font-semibold text-gray-600">Post</th>
                        <th class="text-left px-6 py-4 font-semibold text-gray-600 hidden md:table-cell">Category</th>
                        <th class="text-left px-6 py-4 font-semibold text-gray-600 hidden md:table-cell">Date</th>
                        <th class="text-left px-6 py-4 font-semibold text-gray-600 hidden sm:table-cell">Stats</th>
                        <th class="text-right px-6 py-4 font-semibold text-gray-600">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var post in Model)
                    {
                        <tr class="hover:bg-gray-50 transition">

                            <!-- Post Title & Excerpt -->
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                                    {
                                        <img src="@post.ImageUrl" alt="@post.Title"
                                             class="w-12 h-12 rounded-xl object-cover flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-newspaper text-indigo-300"></i>
                                        </div>
                                    }
                                    <div>
                                        <a asp-action="Detail" asp-controller="BlogPost"
                                           asp-route-slug="@post.Slug"
                                           class="font-medium text-gray-800 hover:text-indigo-600 transition line-clamp-1">
                                            @post.Title
                                        </a>
                                        @if (!string.IsNullOrEmpty(post.Excerpt))
                                        {
                                            <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">@post.Excerpt</p>
                                        }
                                    </div>
                                </div>
                            </td>

                            <!-- Category -->
                            <td class="px-6 py-4 hidden md:table-cell">
                                <span class="bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full text-xs">
                                    @post.CategoryName
                                </span>
                            </td>

                            <!-- Date -->
                            <td class="px-6 py-4 hidden md:table-cell text-gray-400 text-xs">
                                @post.CreatedAt.ToString("MMM dd, yyyy")
                            </td>

                            <!-- Stats -->
                            <td class="px-6 py-4 hidden sm:table-cell">
                                <div class="flex items-center gap-3 text-xs text-gray-400">
                                    <span><i class="fas fa-heart mr-1 text-red-300"></i>@post.LikeCount</span>
                                    <span><i class="fas fa-comment mr-1 text-indigo-300"></i>@post.CommentCount</span>
                                </div>
                            </td>

                            <!-- Actions -->
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Detail" asp-controller="BlogPost"
                                       asp-route-slug="@post.Slug"
                                       class="p-2 text-gray-400 hover:text-indigo-600 transition"
                                       title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-controller="BlogPost"
                                       asp-route-id="@post.Id"
                                       class="p-2 text-gray-400 hover:text-indigo-600 transition"
                                       title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-controller="BlogPost"
                                          method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this post?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@post.Id" />
                                        <button type="submit"
                                                class="p-2 text-gray-400 hover:text-red-500 transition"
                                                title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Summary -->
        <p class="text-sm text-gray-400 mt-4">
            Total: @Model.Count @(Model.Count == 1 ? "post" : "posts")
        </p>
    }
    else
    {
        <!-- Empty State -->
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
            <i class="fas fa-newspaper text-gray-200 text-6xl mb-4"></i>
            <h3 class="text-xl font-bold text-gray-400">No posts yet</h3>
            <p class="text-gray-400 mt-2 mb-6">Start writing your first blog post!</p>
            <a asp-action="Create" asp-controller="BlogPost"
               class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition">
                <i class="fas fa-plus mr-1"></i> Create your first post
            </a>
        </div>
    }

</main>