@model List<CategoryViewModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Categories";
}

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
        <ol class="flex items-center flex-wrap gap-1">
            <li>
                <a asp-action="Index" asp-controller="Home"
                   class="hover:text-indigo-600 transition">Home</a>
            </li>
            <li><span class="mx-2">/</span></li>
            <li class="text-gray-700 font-medium">Categories</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="border-b border-gray-200 pb-6 mb-8">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight">Categories</h1>
        <p class="text-gray-500 text-lg mt-2">Browse all topics and find what interests you.</p>
    </div>

    <!-- Categories Grid -->
    @if (Model.Any())
    {
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var category in Model)
            {
                <a asp-action="Index" asp-controller="Category"
                   asp-route-id="@category.Id"
                   class="bg-white rounded-2xl border border-gray-100 p-6 hover:border-indigo-200 hover:shadow-md transition group">

                    <!-- Icon -->
                    <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-indigo-100 transition">
                        <i class="fas fa-folder text-indigo-500"></i>
                    </div>

                    <!-- Name & Description -->
                    <h2 class="font-bold text-xl group-hover:text-indigo-600 transition">
                        @category.Name
                    </h2>
                    @if (!string.IsNullOrEmpty(category.Description))
                    {
                        <p class="text-gray-500 text-sm mt-2 line-clamp-2">@category.Description</p>
                    }

                    <!-- Post Count & Arrow -->
                    <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
                        <span class="text-sm text-gray-400">
                            <i class="fas fa-newspaper mr-1 text-indigo-300"></i>
                            @category.PostCount @(category.PostCount == 1 ? "post" : "posts")
                        </span>
                        <span class="text-indigo-600 text-sm font-medium">
                            Browse →
                        </span>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
            <i class="fas fa-folder-open text-gray-200 text-6xl mb-4"></i>
            <h3 class="text-xl font-bold text-gray-400">No categories yet</h3>
            <p class="text-gray-400 mt-2">Categories will appear here once created.</p>
        </div>
    }

</main>