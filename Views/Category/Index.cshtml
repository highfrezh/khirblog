@model CategoryDetailViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Name + " · Category";
}

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center flex-wrap gap-1">
            <li>
                <a asp-action="Index" asp-controller="Home"
                   class="hover:text-indigo-600 transition">Home</a>
            </li>
            <li><span class="mx-2">/</span></li>
            <li>
                <a asp-action="Index" asp-controller="BlogPost"
                   class="hover:text-indigo-600 transition">Blog</a>
            </li>
            <li><span class="mx-2">/</span></li>
            <li class="text-gray-700 font-medium" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <!-- Category Header -->
    <div class="border-b border-gray-200 pb-6 mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
            <div>
                <h1 class="text-4xl md:text-5xl font-bold tracking-tight">@Model.Name</h1>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-gray-500 text-lg mt-2 max-w-2xl">@Model.Description</p>
                }
            </div>
            <div class="mt-3 md:mt-0">
                <span class="bg-indigo-50 text-indigo-700 px-4 py-2 rounded-full text-sm font-medium inline-flex items-center gap-1">
                    <i class="far fa-file-alt"></i> @Model.TotalPosts articles
                </span>
            </div>
        </div>
    </div>

    <!-- Sort Bar -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div class="text-sm text-gray-400">
            Showing @((Model.CurrentPage - 1) * 9 + 1)–@(Math.Min(Model.CurrentPage * 9, Model.TotalPosts)) of @Model.TotalPosts posts
        </div>
    </div>

    <!-- Posts Grid -->
    @if (Model.Posts.Any())
    {
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var post in Model.Posts)
            {
                <article class="bg-white rounded-2xl border border-gray-100 p-5 hover-lift transition-soft">

                    <!-- Image or Placeholder -->
                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                    {
                        <img src="@post.ImageUrl" alt="@post.Title"
                             class="w-full h-40 rounded-xl object-cover" />
                    }
                    else
                    {
                        <div class="bg-gradient-to-br from-indigo-50 to-purple-50 w-full h-40 rounded-xl flex items-center justify-center text-indigo-300 text-4xl">
                            <i class="fas fa-newspaper"></i>
                        </div>
                    }

                    <!-- Category & Date -->
                    <div class="flex items-center gap-2 mt-4 text-xs">
                        <span class="bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full">
                            @post.CategoryName
                        </span>
                        <span class="text-gray-400">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>

                    <!-- Title -->
                    <h2 class="font-bold text-lg mt-2">
                        <a asp-action="Detail" asp-controller="BlogPost"
                           asp-route-slug="@post.Slug"
                           class="hover:text-indigo-600 transition">
                            @post.Title
                        </a>
                    </h2>

                    <!-- Excerpt -->
                    @if (!string.IsNullOrEmpty(post.Excerpt))
                    {
                        <p class="text-gray-500 text-sm mt-1 line-clamp-2">@post.Excerpt</p>
                    }

                    <!-- Author & Stats -->
                    <div class="flex items-center justify-between mt-4">
                        <div class="flex items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=@post.AuthorName&background=4f46e5&color=fff&size=28"
                                 class="w-6 h-6 rounded-full" />
                            <span class="text-xs text-gray-500">@post.AuthorName</span>
                        </div>
                        <div class="flex items-center gap-3 text-xs text-gray-400">
                            <span><i class="fas fa-heart mr-1"></i>@post.LikeCount</span>
                            <span><i class="fas fa-comment mr-1"></i>@post.CommentCount</span>
                        </div>
                    </div>
                </article>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="mt-12 flex justify-center items-center gap-2">

                @if (Model.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-controller="Category"
                       asp-route-id="@Model.Id"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-500 hover:bg-indigo-50 transition">
                        <i class="fas fa-chevron-left text-sm"></i>
                    </a>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="Index" asp-controller="Category"
                       asp-route-id="@Model.Id"
                       asp-route-page="@i"
                       class="w-10 h-10 flex items-center justify-center rounded-full border transition
                                          @(i == Model.CurrentPage ? "bg-indigo-600 text-white border-indigo-600" : "border-gray-200 text-gray-700 hover:bg-indigo-50")">
                        @i
                    </a>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-action="Index" asp-controller="Category"
                       asp-route-id="@Model.Id"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-500 hover:bg-indigo-50 transition">
                        <i class="fas fa-chevron-right text-sm"></i>
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
            <i class="fas fa-newspaper text-gray-200 text-6xl mb-4"></i>
            <h3 class="text-xl font-bold text-gray-400">No posts in this category yet</h3>
            <p class="text-gray-400 mt-2">Check back soon!</p>
            <a asp-action="Index" asp-controller="BlogPost"
               class="mt-4 inline-block text-indigo-600 hover:underline text-sm">
                Browse all posts
            </a>
        </div>
    }

    <!-- About Category -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="mt-16 bg-white p-8 rounded-3xl border border-gray-100">
            <h2 class="text-xl font-bold flex items-center gap-2">
                <i class="fas fa-pencil-ruler text-indigo-500"></i>
                About the @Model.Name category
            </h2>
            <p class="text-gray-600 mt-3 leading-relaxed">@Model.Description</p>
        </div>
    }

</main>