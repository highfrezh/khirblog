@{
    Layout = "_Layout";
    ViewData["Title"] = "Contact";
}

<main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Header -->
    <div class="text-center mb-12">
        <span class="text-sm font-semibold text-indigo-600 uppercase tracking-wider">Get in touch</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-2">Contact Us</h1>
        <p class="text-gray-500 text-lg mt-4 max-w-xl mx-auto">
            Have a question, feedback, or just want to say hello? We'd love to hear from you.
        </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">

        <!-- Contact Info -->
        <div class="space-y-4">
            <div class="bg-white rounded-2xl border border-gray-100 p-6">
                <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center mb-3">
                    <i class="fas fa-envelope text-indigo-500"></i>
                </div>
                <h3 class="font-bold">Email</h3>
                <p class="text-sm text-gray-500 mt-1">hello@zenblog.com</p>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 p-6">
                <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center mb-3">
                    <i class="fab fa-twitter text-purple-500"></i>
                </div>
                <h3 class="font-bold">Twitter</h3>
                <p class="text-sm text-gray-500 mt-1">@@zenblog</p>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 p-6">
                <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center mb-3">
                    <i class="fas fa-clock text-green-500"></i>
                </div>
                <h3 class="font-bold">Response Time</h3>
                <p class="text-sm text-gray-500 mt-1">Within 24 hours</p>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="md:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
            <h2 class="text-xl font-bold mb-6">Send a message</h2>
            <form class="space-y-5">

                <!-- Name & Email -->
                <div class="grid sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input type="text" placeholder="Your name"
                               class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" placeholder="your@email.com"
                               class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                    </div>
                </div>

                <!-- Subject -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
                    <input type="text" placeholder="How can we help?"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                </div>

                <!-- Message -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                    <textarea rows="5" placeholder="Your message..."
                              class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none"></textarea>
                </div>

                <button type="submit"
                        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-full font-medium transition">
                    <i class="fas fa-paper-plane mr-2"></i> Send Message
                </button>
            </form>
        </div>
    </div>
</main>