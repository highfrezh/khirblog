@{
    Layout = "_Layout";
    ViewData["Title"] = "Privacy Policy";
}

<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Header -->
    <div class="mb-10">
        <h1 class="text-4xl font-bold">Privacy Policy</h1>
        <p class="text-gray-500 mt-2">Last updated: January 1, 2025</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 space-y-8 text-gray-600 leading-relaxed">

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">1. Information We Collect</h2>
            <p>
                When you register on zenblog, we collect your name and email address. We also collect
                information you voluntarily provide such as blog posts, comments, and profile details.
                We may collect usage data such as pages visited and time spent on the site.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">2. How We Use Your Information</h2>
            <p>
                We use the information we collect to operate and improve zenblog, send you
                updates and newsletters if you've opted in, respond to your comments and questions,
                and personalize your experience on the platform.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">3. Information Sharing</h2>
            <p>
                We do not sell, trade, or otherwise transfer your personal information to third parties.
                Your public profile information such as your name and published posts will be visible
                to other users of the platform.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">4. Data Security</h2>
            <p>
                We implement appropriate security measures to protect your personal information.
                Your password is encrypted and never stored in plain text. However, no method of
                transmission over the internet is 100% secure.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">5. Cookies</h2>
            <p>
                We use cookies to keep you logged in and remember your preferences.
                You can disable cookies in your browser settings, but this may affect
                the functionality of the site.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">6. Your Rights</h2>
            <p>
                You have the right to access, update, or delete your personal information at any time
                through your profile settings. You may also contact us directly to request data deletion.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">7. Contact Us</h2>
            <p>
                If you have any questions about this Privacy Policy, please
                <a asp-action="Contact" asp-controller="Page" class="text-indigo-600 hover:underline">contact us</a>.
            </p>
        </section>

    </div>
</main>