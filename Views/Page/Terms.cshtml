@{
    Layout = "_Layout";
    ViewData["Title"] = "Terms of Service";
}

<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Header -->
    <div class="mb-10">
        <h1 class="text-4xl font-bold">Terms of Service</h1>
        <p class="text-gray-500 mt-2">Last updated: January 1, 2025</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 space-y-8 text-gray-600 leading-relaxed">

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">1. Acceptance of Terms</h2>
            <p>
                By accessing and using zenblog, you accept and agree to be bound by these
                Terms of Service. If you do not agree to these terms, please do not use our platform.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">2. User Accounts</h2>
            <p>
                You are responsible for maintaining the confidentiality of your account credentials.
                You agree to provide accurate information when registering and to keep your profile
                information up to date. You must be at least 13 years old to use zenblog.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">3. Content Guidelines</h2>
            <p>
                You retain ownership of content you publish on zenblog. By publishing, you grant
                us a non-exclusive license to display your content on our platform. You agree not to
                post content that is illegal, harmful, offensive, or infringes on others' rights.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">4. Prohibited Activities</h2>
            <p>
                You agree not to spam, harass other users, attempt to gain unauthorized access
                to the platform, or use automated tools to scrape content. Violations may result
                in account suspension or termination.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">5. Intellectual Property</h2>
            <p>
                The zenblog platform, including its design and code, is owned by us and protected
                by intellectual property laws. You may not copy or reproduce any part of the platform
                without our express written permission.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">6. Limitation of Liability</h2>
            <p>
                zenblog is provided "as is" without warranties of any kind. We are not liable for
                any damages arising from your use of the platform or content published by other users.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">7. Changes to Terms</h2>
            <p>
                We reserve the right to modify these terms at any time. Continued use of the
                platform after changes constitutes acceptance of the new terms.
            </p>
        </section>

        <section>
            <h2 class="text-xl font-bold text-gray-800 mb-3">8. Contact</h2>
            <p>
                For questions about these terms, please
                <a asp-action="Contact" asp-controller="Page" class="text-indigo-600 hover:underline">contact us</a>.
            </p>
        </section>

    </div>
</main>