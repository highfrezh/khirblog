@model ChangePasswordViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Change Password";
}

<main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold">Change Password</h1>
        <a asp-action="Index" asp-controller="Profile"
           class="text-gray-400 hover:text-indigo-600 transition">
            <i class="fas fa-times text-xl"></i>
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <form asp-action="ChangePassword" asp-controller="Profile" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly"
                 class="text-red-500 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>

            <!-- Current Password -->
            <div>
                <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-700 mb-1">
                    Current Password
                </label>
                <input asp-for="CurrentPassword" placeholder="••••••••"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="CurrentPassword" class="text-red-500 text-sm"></span>
            </div>

            <!-- New Password -->
            <div>
                <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-1">
                    New Password
                </label>
                <input asp-for="NewPassword" placeholder="at least 6 characters"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="NewPassword" class="text-red-500 text-sm"></span>
            </div>

            <!-- Confirm New Password -->
            <div>
                <label asp-for="ConfirmNewPassword" class="block text-sm font-medium text-gray-700 mb-1">
                    Confirm New Password
                </label>
                <input asp-for="ConfirmNewPassword" placeholder="••••••••"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="ConfirmNewPassword" class="text-red-500 text-sm"></span>
            </div>

            <!-- Actions -->
            <div class="flex gap-3 justify-end pt-4 border-t border-gray-100">
                <a asp-action="Index" asp-controller="Profile"
                   class="px-6 py-2.5 border border-gray-200 rounded-full text-sm font-medium transition hover:border-gray-300">
                    Cancel
                </a>
                <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition">
                    <i class="fas fa-lock mr-1"></i> Change Password
                </button>
            </div>
        </form>
    </div>
</main>