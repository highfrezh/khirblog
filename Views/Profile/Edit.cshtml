@model EditProfileViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Profile";
}

<main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold">Edit Profile</h1>
        <a asp-action="Index" asp-controller="Profile"
           class="text-gray-400 hover:text-indigo-600 transition">
            <i class="fas fa-times text-xl"></i>
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <form asp-action="Edit" asp-controller="Profile" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly"
                 class="text-red-500 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>

            <!-- First Name & Last Name -->
            <div class="grid sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">
                        First Name
                    </label>
                    <input asp-for="FirstName"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                    <span asp-validation-for="FirstName" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1">
                        Last Name
                    </label>
                    <input asp-for="LastName"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                    <span asp-validation-for="LastName" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <!-- Email -->
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">
                    Email
                </label>
                <input asp-for="Email"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-300 focus:outline-none" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <!-- Actions -->
            <div class="flex gap-3 justify-end pt-4 border-t border-gray-100">
                <a asp-action="Index" asp-controller="Profile"
                   class="px-6 py-2.5 border border-gray-200 rounded-full text-sm font-medium transition hover:border-gray-300">
                    Cancel
                </a>
                <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</main>