@model ProfileViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "My Profile";
}

<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Success Message -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-6">
            <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
        </div>
    }

    <!-- Profile Header -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 mb-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">

            <!-- Avatar -->
            <div class="w-20 h-20 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-3xl font-bold flex-shrink-0">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>

            <!-- Info -->
            <div class="flex-1">
                <h1 class="text-2xl font-bold">@Model.FullName</h1>
                <p class="text-gray-500 mt-1">@Model.Email</p>
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center gap-3">
                <a asp-action="Edit" asp-controller="Profile"
                   class="px-5 py-2.5 border border-gray-200 hover:border-indigo-300 rounded-full text-sm font-medium transition">
                    <i class="fas fa-edit mr-1"></i> Edit Profile
                </a>
                <a asp-action="ChangePassword" asp-controller="Profile"
                   class="px-5 py-2.5 border border-gray-200 hover:border-indigo-300 rounded-full text-sm font-medium transition">
                    <i class="fas fa-lock mr-1"></i> Change Password
                </a>
            </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mt-8 pt-6 border-t border-gray-100">
            <div class="text-center">
                <p class="text-3xl font-bold text-indigo-600">@Model.TotalPosts</p>
                <p class="text-sm text-gray-500 mt-1">Posts</p>
            </div>
            <div class="text-center">
                <p class="text-3xl font-bold text-red-400">@Model.TotalLikes</p>
                <p class="text-sm text-gray-500 mt-1">Likes received</p>
            </div>
            <div class="text-center">
                <p class="text-3xl font-bold text-green-500">@Model.TotalComments</p>
                <p class="text-sm text-gray-500 mt-1">Comments</p>
            </div>
        </div>
    </div>

    <!-- Recent Posts -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h2 class="font-bold text-lg">My Recent Posts</h2>
            <a asp-action="MyPosts" asp-controller="BlogPost"
               class="text-sm text-indigo-600 hover:underline">
                View all →
            </a>
        </div>

        @if (Model.RecentPosts.Any())
        {
            <div class="divide-y divide-gray-50">
                @foreach (var post in Model.RecentPosts)
                {
                    <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition">

                        <!-- Image or Placeholder -->
                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl" alt="@post.Title"
                                 class="w-12 h-12 rounded-xl object-cover flex-shrink-0" />
                        }
                        else
                        {
                            <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-newspaper text-indigo-300"></i>
                            </div>
                        }

                        <!-- Post Info -->
                        <div class="flex-1 min-w-0">
                            <a asp-action="Detail" asp-controller="BlogPost"
                               asp-route-slug="@post.Slug"
                               class="font-medium hover:text-indigo-600 transition line-clamp-1">
                                @post.Title
                            </a>
                            <div class="flex items-center gap-3 mt-1 text-xs text-gray-400">
                                <span>@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                <span>·</span>
                                <span class="bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full">
                                    @post.CategoryName
                                </span>
                            </div>
                        </div>

                        <!-- Stats -->
                        <div class="flex items-center gap-4 text-xs text-gray-400 flex-shrink-0">
                            <span><i class="fas fa-heart mr-1 text-red-300"></i>@post.LikeCount</span>
                            <span><i class="fas fa-comment mr-1 text-indigo-300"></i>@post.CommentCount</span>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <a asp-action="Edit" asp-controller="BlogPost"
                               asp-route-id="@post.Id"
                               class="p-2 text-gray-400 hover:text-indigo-600 transition">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-controller="BlogPost"
                                  method="post"
                                  onsubmit="return confirm('Delete this post?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@post.Id" />
                                <button type="submit"
                                        class="p-2 text-gray-400 hover:text-red-500 transition">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-16 text-gray-400">
                <i class="fas fa-newspaper text-5xl mb-4 text-gray-200"></i>
                <p class="font-medium">No posts yet</p>
                <p class="text-sm mt-1">Start writing your first blog post!</p>
                <a asp-action="Create" asp-controller="BlogPost"
                   class="mt-4 inline-block bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-full text-sm font-medium transition">
                    <i class="fas fa-plus mr-1"></i> Create Post
                </a>
            </div>
        }
    </div>
</main>