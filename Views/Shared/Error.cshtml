@{
    Layout = "_Layout";
    ViewData["Title"] = "Error";
}

<main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">

    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-12">

        <!-- Icon -->
        <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-exclamation-triangle text-red-400 text-3xl"></i>
        </div>

        <h1 class="text-4xl font-bold text-gray-800">Oops!</h1>
        <p class="text-gray-500 text-lg mt-3">
            Something went wrong. We're working on fixing it.
        </p>

        <div class="flex flex-wrap gap-4 justify-center mt-8">
            <a asp-action="Index" asp-controller="Home"
               class="bg-indigo-600 hover:bg-indigo-700 text-white px-7 py-3 rounded-full font-medium transition">
                <i class="fas fa-home mr-2"></i> Go Home
            </a>
            <a href="javascript:history.back()"
               class="border border-gray-200 hover:border-indigo-300 px-7 py-3 rounded-full font-medium text-gray-700 transition">
                <i class="fas fa-arrow-left mr-2"></i> Go Back
            </a>
        </div>
    </div>
</main>