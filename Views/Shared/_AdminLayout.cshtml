<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] · zenblog Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="bg-gray-100 text-gray-800 font-sans antialiased">

    <!-- Top Bar -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
            <div class="flex items-center gap-2">
                <i class="fas fa-cog text-indigo-600"></i>
                <a asp-action="Index" asp-controller="AdminDashboard"
                   class="font-bold text-xl">
                    zenblog <span class="text-indigo-600">admin</span>
                </a>
            </div>
            <div class="flex items-center gap-4">
                <a asp-action="Index" asp-controller="Home"
                   class="text-sm text-gray-500 hover:text-indigo-600 transition">
                    <i class="fas fa-globe mr-1"></i> View Site
                </a>
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-indigo-600 rounded-full flex items-center justify-center text-white text-sm font-bold">
                        @User.Identity!.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <span class="text-sm font-medium hidden sm:block">@User.Identity.Name</span>
                </div>
                <form asp-action="Logout" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="text-sm text-red-400 hover:text-red-600 transition">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex gap-6">

        <!-- Sidebar -->
        <aside class="w-64 flex-shrink-0">
            <div class="bg-white rounded-2xl border border-gray-100 p-4 sticky top-24">
                <nav class="space-y-1">
                    <a asp-action="Index" asp-controller="AdminDashboard"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                              @(ViewData["Title"]?.ToString() == "Admin Dashboard" ? "bg-indigo-50 text-indigo-700" : "text-gray-600 hover:bg-gray-50") transition">
                        <i class="fas fa-chart-pie w-4"></i> Dashboard
                    </a>
                    <a asp-action="Index" asp-controller="AdminBlogPost"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                              @(ViewData["Title"]?.ToString() == "Manage Posts" ? "bg-indigo-50 text-indigo-700" : "text-gray-600 hover:bg-gray-50") transition">
                        <i class="fas fa-file-alt w-4"></i> Posts
                    </a>
                    <a asp-action="Index" asp-controller="AdminUser"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                              @(ViewData["Title"]?.ToString() == "Manage Users" ? "bg-indigo-50 text-indigo-700" : "text-gray-600 hover:bg-gray-50") transition">
                        <i class="fas fa-users w-4"></i> Users
                    </a>
                    <a asp-action="Index" asp-controller="AdminCategory"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                              @(ViewData["Title"]?.ToString() == "Manage Categories" ? "bg-indigo-50 text-indigo-700" : "text-gray-600 hover:bg-gray-50") transition">
                        <i class="fas fa-folder w-4"></i> Categories
                    </a>
                    <a asp-action="Index" asp-controller="AdminTag"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                              @(ViewData["Title"]?.ToString() == "Manage Tags" ? "bg-indigo-50 text-indigo-700" : "text-gray-600 hover:bg-gray-50") transition">
                        <i class="fas fa-tags w-4"></i> Tags
                    </a>
                    <a asp-action="Index" asp-controller="AdminComment"
                       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                              @(ViewData["Title"]?.ToString() == "Manage Comments" ? "bg-indigo-50 text-indigo-700" : "text-gray-600 hover:bg-gray-50") transition">
                        <i class="fas fa-comments w-4"></i> Comments
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 min-w-0">

            <!-- Success/Error Messages -->
            @if (TempData["Success"] != null)
            {
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm mb-6">
                    <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-6">
                    <i class="fas fa-exclamation-circle mr-2"></i> @TempData["Error"]
                </div>
            }

            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)

</body>
</html>