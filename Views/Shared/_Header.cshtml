<header class="bg-white/90 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-30">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">

        <!-- Logo -->
        <a asp-action="Index" asp-controller="Home"
           class="text-2xl font-bold text-indigo-600 tracking-tight">
            khir<span class="text-gray-800">blog</span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex space-x-8 text-sm font-medium">
            <a asp-action="Index" asp-controller="Home"
               class="hover:text-indigo-600 transition">Home</a>

            <a asp-action="Index" asp-controller="BlogPost"
               class="hover:text-indigo-600 transition">Blog</a>

            <!-- Categories Dropdown -->
            <div class="relative group">
                <button class="flex items-center gap-1 hover:text-indigo-600 transition">
                    Categories
                    <i class="fas fa-chevron-down text-xs mt-0.5"></i>
                </button>

                <!-- Dropdown -->
                <div class="absolute left-0 mt-3 w-52 bg-white rounded-xl shadow-lg border border-gray-100 py-2
                            invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 z-50">

                    <a asp-action="All" asp-controller="Category"
                       class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition">
                        <i class="fas fa-th-large text-indigo-300 w-4"></i> All Categories
                    </a>

                    <hr class="my-1 border-gray-100" />

                    @* We need to pass categories from ViewBag *@
                    <hr class="my-1 border-gray-100" />

                    @{
                        var headerCategories = ViewBag.HeaderCategories as IEnumerable<BlogApp.Models.Category>;
                    }

                    @if (headerCategories != null && headerCategories.Any())
                    {
                        @foreach (var category in headerCategories)
                        {
                            <a asp-action="Index" asp-controller="BlogPost"
                               asp-route-categoryId="@category.Id"
                               class="flex items-center justify-between px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition">
                                <span>@category.Name</span>
                                <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
                                    @category.BlogPosts.Count
                                </span>
                            </a>
                        }
                    }
                </div>
            </div>

            <a asp-action="About" asp-controller="Page" class="hover:text-indigo-600">About</a>
            <a asp-action="Contact" asp-controller="Page" class="hover:text-indigo-600">Contact</a>
        </div>

        <!-- Right Side -->
        <div class="flex items-center gap-3">
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="hidden sm:flex items-center gap-3">
                    <a asp-action="Create" asp-controller="BlogPost"
                       class="hidden sm:inline-block text-sm text-gray-600 hover:text-indigo-600 transition">
                        <i class="fas fa-pen mr-1"></i> Write
                    </a>

                    <!-- User dropdown -->
                    <div class="relative group">
                        <button class="flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-indigo-600 transition">
                            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold">
                                @User.Identity.Name?.Substring(0, 1).ToUpper()
                            </div>
                            <span class="hidden sm:block">@User.Identity.Name</span>
                            <i class="fas fa-chevron-down text-xs"></i>
                        </button>

                        <!-- User Dropdown -->
                        <div class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 py-2
                                        invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 z-50">

                            <a asp-action="Index" asp-controller="Profile"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition">
                                <i class="fas fa-user w-4"></i> My Profile
                            </a>

                            <a asp-action="MyPosts" asp-controller="BlogPost"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition">
                                <i class="fas fa-newspaper w-4"></i> My Posts
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Admin/Dashboard/Index"
                                   class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition">
                                    <i class="fas fa-cog w-4"></i> Admin Dashboard
                                </a>
                            }

                            <hr class="my-2 border-gray-100" />

                            <form asp-action="Logout" asp-controller="Account" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-500 hover:bg-red-50 transition">
                                    <i class="fas fa-sign-out-alt w-4"></i> Logout
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <a asp-action="Login" asp-controller="Account"
                   class="hidden sm:inline-block text-sm text-gray-600 hover:text-indigo-600 transition">
                    Sign in
                </a>
                <a asp-action="Register" asp-controller="Account"
                   class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-5 py-2 rounded-full font-medium transition">
                    Get Started
                </a>
            }

            <!-- Mobile menu button -->
            <button class="md:hidden text-gray-500 text-xl" aria-label="Menu">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="md:hidden hidden border-t border-gray-100 px-4 py-4 space-y-3 bg-white" id="mobileMenu">
        <a asp-action="Index" asp-controller="Home"
           class="block text-sm font-medium text-gray-700 hover:text-indigo-600">Home</a>
        <a asp-action="Index" asp-controller="BlogPost"
           class="block text-sm font-medium text-gray-700 hover:text-indigo-600">Blog</a>

        <!-- Mobile Categories -->
        <div>
            <p class="text-sm font-medium text-gray-700 mb-2">Categories</p>
            <div class="pl-3 space-y-2">
                <a asp-action="All" asp-controller="Category"
                   class="block text-sm text-gray-500 hover:text-indigo-600">
                    All Categories
                </a>
                @if (headerCategories != null && headerCategories.Any())
                {
                    @foreach (var category in headerCategories)
                    {
                        <a asp-action="Index" asp-controller="BlogPost"
                           asp-route-categoryId="@category.Id"
                           class="block text-sm text-gray-500 hover:text-indigo-600">
                            @category.Name
                        </a>
                    }
                }
            </div>
        </div>

        <a href="#" class="block text-sm font-medium text-gray-700 hover:text-indigo-600">About</a>
        <a href="#" class="block text-sm font-medium text-gray-700 hover:text-indigo-600">Contact</a>

        @if (User.Identity!.IsAuthenticated)
        {
            <hr class="border-gray-100" />
            <a asp-action="Create" asp-controller="BlogPost"
               class="block text-sm font-medium text-gray-700 hover:text-indigo-600">
                <i class="fas fa-pen mr-1"></i> Write
            </a>
            <a asp-action="Index" asp-controller="Profile"
               class="block text-sm font-medium text-gray-700 hover:text-indigo-600">
                <i class="fas fa-user mr-1"></i> My Profile
            </a>
            <form asp-action="Logout" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="text-sm font-medium text-red-500 hover:text-red-600">
                    <i class="fas fa-sign-out-alt mr-1"></i> Logout
                </button>
            </form>
        }
        else
        {
            <hr class="border-gray-100" />
            <a asp-action="Login" asp-controller="Account"
               class="block text-sm font-medium text-gray-700 hover:text-indigo-600">Sign in</a>
            <a asp-action="Register" asp-controller="Account"
               class="block text-sm font-medium text-indigo-600">Get Started</a>
        }
    </div>
</header>

<script>
    document.querySelector('[aria-label="Menu"]').addEventListener('click', function () {
        const menu = document.getElementById('mobileMenu');
        menu.classList.toggle('hidden');
    });
</script>